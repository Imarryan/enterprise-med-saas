# Environment Variables
# Copy this to .env and fill in your values

# ─── Database ─────────────────────────────────────────────────────────────────
# Replace with your PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/meddb?schema=public"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32  (or any random 32+ char string)
NEXTAUTH_SECRET="your-super-secret-key-replace-this"
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth (optional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# ─── Stripe (optional) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ─── WhatsApp Business API (optional) ─────────────────────────────────────────
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""

# ─── App Config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="MedLearn Pro"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
